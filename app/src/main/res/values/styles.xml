    </style>

    <!--https://m2.material.io/develop/android/theming/shape -->
    <style name="ShapeAppearanceOverlay.Crave.CircleImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!--================================-->
    <!--    LEADERBOARD STAT CARDS      -->
