<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/warm_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/warm_white">

        <!-- Banner Image -->
        <ImageView
            android:id="@+id/bannerImage"
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:scaleType="centerCrop"
            android:src="@drawable/kelowna_banner"
            android:contentDescription="Kelowna banner image" />

        <!-- Profile Avatar -->
        <ImageView
            android:id="@+id/profileImage"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center"
            android:layout_marginTop="-35dp"
            android:src="@drawable/avatar1"
            android:contentDescription="Profile avatar" />

        <!-- Name -->
        <TextView
            android:id="@+id/nameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:text="Kyle K."
            android:textColor="@color/deep_lagoon"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Username -->
        <TextView
            android:id="@+id/usernameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="username"
            android:textColor="@color/deep_lagoon"
            android:textSize="13sp" />

        <!-- Bio -->
        <TextView
            android:id="@+id/bioText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:text="Exploring Kelowna on wheels"
            android:textColor="@color/deep_lagoon"
            android:textSize="13sp" />

        <!-- Stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/distanceText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:text="120 km"
                android:textColor="@color/deep_lagoon"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/visitsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8 visits"
                android:textColor="@color/deep_lagoon"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/editButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingLeft="14dp"
                android:paddingTop="6dp"
                android:paddingRight="14dp"
                android:paddingBottom="6dp"
                android:text="Edit Profile"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:backgroundTint="@color/electric_teal" />

            <Button
                android:id="@+id/settingsButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:layout_marginStart="10dp"
                android:paddingLeft="14dp"
                android:paddingTop="6dp"
                android:paddingRight="14dp"
                android:paddingBottom="6dp"
                android:text="Settings"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:backgroundTint="@color/blaze_orange" />
        </LinearLayout>

        <!-- Achievements Main Title -->
        <TextView
            android:id="@+id/achievementTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginStart="16dp"
            android:text="Achievements"
            android:textColor="@color/deep_lagoon"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/achievementHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="2dp"
            android:text="Tap a badge to learn more"
            android:textColor="@color/deep_lagoon"
            android:textSize="12sp" />

        <!-- Distance Category -->
        <TextView
            android:id="@+id/distanceCategoryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="16dp"
            android:text="Distance Badges"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/electric_teal" />

        <HorizontalScrollView
            android:id="@+id/distanceScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <LinearLayout
                    android:id="@+id/badgeFirstRide"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="53dp"
                        android:layout_height="53dp"
                        android:background="@drawable/circle_badge_teal"
                        android:padding="7dp"
                        android:src="@drawable/ic_bike"
                        android:contentDescription="First Ride badge" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="First Ride"
                        android:textColor="@color/deep_lagoon"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/badge10km"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="53dp"
                        android:layout_height="53dp"
                        android:background="@drawable/circle_badge_teal"
                        android:padding="7dp"
                        android:src="@drawable/ic_trophy"
                        android:contentDescription="10 KM badge" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="10 KM"
                        android:textColor="@color/deep_lagoon"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/badge50km"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="53dp"
                        android:layout_height="53dp"
                        android:background="@drawable/circle_badge_teal"
                        android:padding="7dp"
                        android:src="@drawable/ic_trophy"
                        android:contentDescription="50 KM badge" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="50 KM"
                        android:textColor="@color/deep_lagoon"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Visit Category -->
        <TextView
            android:id="@+id/visitCategoryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="16dp"
            android:text="Visit Badges"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/blaze_orange" />

        <HorizontalScrollView
            android:id="@+id/visitScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <LinearLayout
                    android:id="@+id/badgeFirstVisit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="53dp"
                        android:layout_height="53dp"
                        android:background="@drawable/circle_badge_orange"
                        android:padding="7dp"
                        android:src="@drawable/ic_discover"
                        android:contentDescription="First Visit badge" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="First Visit"
                        android:textColor="@color/deep_lagoon"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/badgeFoodie"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="53dp"
                        android:layout_height="53dp"
                        android:background="@drawable/circle_badge_orange"
                        android:padding="7dp"
                        android:src="@drawable/ic_trophy"
                        android:contentDescription="Foodie badge" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Foodie"
                        android:textColor="@color/deep_lagoon"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/badgeLocalTourist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="53dp"
                        android:layout_height="53dp"
                        android:background="@drawable/circle_badge_orange"
                        android:padding="7dp"
                        android:src="@drawable/ic_profile"
                        android:contentDescription="Local Tourist badge" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Local Tourist"
                        android:textColor="@color/deep_lagoon"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Consistency Category -->
        <TextView
            android:id="@+id/consistencyCategoryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="16dp"
            android:text="Consistency Badges"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/sunlit_gold" />

        <HorizontalScrollView
            android:id="@+id/consistencyScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <LinearLayout
                    android:id="@+id/badgeWeekendCyclist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="53dp"
                        android:layout_height="53dp"
                        android:background="@drawable/circle_badge_gold"
                        android:padding="7dp"
                        android:src="@drawable/ic_bike"
                        android:contentDescription="Weekend Cyclist badge" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Weekend Cyclist"
                        android:textColor="@color/deep_lagoon"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/badgeConsistentRider"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="53dp"
                        android:layout_height="53dp"
                        android:background="@drawable/circle_badge_gold"
                        android:padding="7dp"
                        android:src="@drawable/ic_trophy"
                        android:contentDescription="Consistent Rider badge" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Consistent Rider"
                        android:textColor="@color/deep_lagoon"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </HorizontalScrollView>

    </LinearLayout>
</ScrollView>