<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardback"
    android:layout_width="@dimen/prize_width"
    android:layout_height="@dimen/prize_depth"
    android:layout_gravity="center_horizontal"
    android:clickable="false"
    android:focusable="false"
    android:checkable="false"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/sunlit_gold"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="5dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/textView"
            style="@style/FirstPlacePrizeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1st Place Prize"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/textView2"
            style="@style/FirstPlacePrizeBody"
            android:layout_width="164dp"
            android:layout_height="wrap_content"
            android:text="$200 Gift Card to this months sponsor,"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView" />

        <TextView
            android:id="@+id/textView3"
            style="@style/FirstPlacePrizeComp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Yama Kitchen!"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView2" />

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="162dp"
            android:layout_height="124dp"
            android:layout_marginTop="4dp"
            android:scaleType="centerCrop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/yama_kitchen" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>